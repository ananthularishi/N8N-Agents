    {
      "parameters": {
        "jsCode": "// Parse AI output into proper JSON array\nconst rawOutput = $json.output || $json.text || \"\";\n\nlet schools = [];\n\ntry {\n  // Try to find JSON array in output\n  const jsonMatch = rawOutput.match(/\\[([\\s\\S]*?)\\]/);\n  if (jsonMatch) {\n    schools = JSON.parse(jsonMatch[0]);\n  } else {\n    schools = JSON.parse(rawOutput);\n  }\n} catch (e) {\n  console.log(\"Parse error:\", e.message);\n  schools = [];\n}\n\n// Return each school as separate item\nif (schools.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\nreturn schools.map(school => ({\n  json: {\n    school_name: school.school_name || \"\",\n    district: school.district || \"\",\n    website: school.website || \"\",\n    offers_iit: school.offers_iit || false,\n    offers_neet: school.offers_neet || false\n  }\n}));"
      },

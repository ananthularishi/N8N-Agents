    {
      "parameters": {
        "jsCode": "// Parse contact JSON from AI output\nconst rawOutput = $json.output || $json.text || \"\";\n\nlet contact = {};\n\ntry {\n  // Find JSON object in output\n  const jsonMatch = rawOutput.match(/\\{([\\s\\S]*?)\\}/);\n  if (jsonMatch) {\n    contact = JSON.parse(jsonMatch[0]);\n  } else {\n    contact = JSON.parse(rawOutput);\n  }\n} catch (e) {\n  console.log(\"Parse error:\", e.message);\n  contact = {\n    school_name: \"\",\n    email: \"\",\n    phone: \"\",\n    website: \"\",\n    location: \"\",\n    district: \"\",\n    has_app: false\n  };\n}\n\n// Only return if email exists\nif (!contact.email || contact.email === \"\") {\n  return [{ json: { skip_email: true, ...contact } }];\n}\n\nreturn [{ json: contact }];"
      },

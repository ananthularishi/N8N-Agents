    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a contact information extraction assistant.\n\nExtract contact details for this school: {{$json.school_name}}\n\nReturn ONLY this exact JSON format, no markdown, no extra text:\n\n{\n  \"school_name\": \"{{$json.school_name}}\",\n  \"email\": \"extracted email or empty string\",\n  \"phone\": \"extracted phone number or empty string\",\n  \"website\": \"extracted website URL or empty string\",\n  \"location\": \"full address or city\",\n  \"district\": \"{{$json.district}}\",\n  \"has_app\": false\n}\n\nRULES:\n- Only real email addresses\n- NOT example@domain.com\n- If no email found use empty string\n- Return ONE JSON object only\n- No explanation, only JSON\n\nSearch Results:\n{{ JSON.stringify($json.results) }}",
        "options": {}
